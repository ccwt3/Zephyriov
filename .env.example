# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Contact info sent in the User-Agent to the Lichess / Chess.com APIs.
# Chess.com tries to reach this contact before blocking an app, so setting it
# is recommended. Use an email or your repo URL — whatever you're fine having
# leave your server on every request.
# Optional: without it the requests still identify the app, just anonymously.
APP_CONTACT=you@example.com
